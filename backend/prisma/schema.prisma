generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserProfile {
  ADMIN
  MANAGER
  OPERATOR
  REVIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_SETUP
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RequisitionStatus {
  DRAFT
  SUBMITTED
  IN_APPROVAL
  APPROVED
  REJECTED
  CONVERTED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  IN_APPROVAL
  APPROVED
  SENT_TO_SUPPLIER
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
  INTEGRATED
}

enum ReceivingStatus {
  DRAFT
  CONFIRMED
  DIVERGENT
  CANCELLED
}

enum ItemType {
  PRODUCT
  SERVICE
}

// ============================================================
// USUÁRIOS
// ============================================================

model User {
  id          String     @id @default(uuid()) @db.UniqueIdentifier
  email       String     @unique @db.NVarChar(255)
  name        String     @db.NVarChar(255)
  adUsername  String?    @db.NVarChar(255)
  profile     UserProfile
  status      UserStatus @default(PENDING_SETUP)
  companyIds  String     @db.NVarChar(Max) // JSON array: ["comp1","comp2"]
  branchIds   String     @db.NVarChar(Max) // JSON array
  costCenterIds String   @db.NVarChar(Max) // JSON array
  approvalLimit Decimal? @db.Decimal(15, 2)
  delegateTo  String?    @db.UniqueIdentifier
  delegateFrom String?   @db.UniqueIdentifier
  delegateUntil DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  approvalRules ApprovalRule[]
  requisitions  Requisition[]
  purchaseOrders PurchaseOrder[]

  @@map("users")
}

// ============================================================
// EMPRESAS E FILIAIS
// ============================================================

model Company {
  id        String   @id @default(uuid()) @db.UniqueIdentifier
  code      String   @unique @db.NVarChar(20)
  name      String   @db.NVarChar(255)
  cnpj      String   @unique @db.NVarChar(20)
  erpDbName String   @db.NVarChar(100) // ex: ERP_EMPRESA1_DB
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  branches    Branch[]
  costCenters CostCenter[]

  @@map("companies")
}

model Branch {
  id        String   @id @default(uuid()) @db.UniqueIdentifier
  companyId String   @db.UniqueIdentifier
  code      String   @db.NVarChar(20)
  name      String   @db.NVarChar(255)
  cnpj      String   @db.NVarChar(20)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@map("branches")
}

model CostCenter {
  id          String   @id @default(uuid()) @db.UniqueIdentifier
  companyId   String   @db.UniqueIdentifier
  code        String   @db.NVarChar(20)
  name        String   @db.NVarChar(255)
  managerId   String?  @db.UniqueIdentifier
  budgetYear  Int?
  budgetTotal Decimal? @db.Decimal(15, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@map("cost_centers")
}

// ============================================================
// FORNECEDORES
// ============================================================

model Supplier {
  id             String   @id @default(uuid()) @db.UniqueIdentifier
  companyId      String   @db.UniqueIdentifier
  code           String   @db.NVarChar(20)
  name           String   @db.NVarChar(255)
  tradeName      String?  @db.NVarChar(255)
  cnpjCpf        String   @db.NVarChar(20)
  email          String?  @db.NVarChar(255)
  phone          String?  @db.NVarChar(20)
  erpSupplierId  String?  @db.NVarChar(50)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  purchaseOrders PurchaseOrder[]

  @@unique([companyId, code])
  @@map("suppliers")
}

// ============================================================
// ITENS / CATÁLOGO
// ============================================================

model Item {
  id               String   @id @default(uuid()) @db.UniqueIdentifier
  companyId        String   @db.UniqueIdentifier
  code             String   @db.NVarChar(50)
  description      String   @db.NVarChar(500)
  type             ItemType @default(PRODUCT)
  unit             String   @db.NVarChar(20)
  accountingCode   String?  @db.NVarChar(50)
  erpItemId        String?  @db.NVarChar(50)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@unique([companyId, code])
  @@map("items")
}

// ============================================================
// REGRAS DE APROVAÇÃO
// ============================================================

model ApprovalRule {
  id            String   @id @default(uuid()) @db.UniqueIdentifier
  companyId     String   @db.UniqueIdentifier
  name          String   @db.NVarChar(255)
  approverId    String   @db.UniqueIdentifier
  minAmount     Decimal? @db.Decimal(15, 2)
  maxAmount     Decimal? @db.Decimal(15, 2)
  costCenterIds String?  @db.NVarChar(Max) // JSON array
  order         Int      @default(1)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  approver User @relation(fields: [approverId], references: [id])

  @@map("approval_rules")
}

// ============================================================
// REQUISIÇÕES
// ============================================================

model Requisition {
  id           String            @id @default(uuid()) @db.UniqueIdentifier
  number       String            @unique @db.NVarChar(20) // REQ-2026-000001
  companyId    String            @db.UniqueIdentifier
  branchId     String            @db.UniqueIdentifier
  costCenterId String            @db.UniqueIdentifier
  requesterId  String            @db.UniqueIdentifier
  title        String            @db.NVarChar(500)
  justification String?          @db.NVarChar(Max)
  status       RequisitionStatus @default(DRAFT)
  totalAmount  Decimal           @db.Decimal(15, 2) @default(0)
  neededBy     DateTime?
  submittedAt  DateTime?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectionReason String?        @db.NVarChar(Max)
  convertedToOcId String?        @db.UniqueIdentifier
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  requester   User              @relation(fields: [requesterId], references: [id])
  items       RequisitionItem[]
  approvals   ApprovalFlow[]

  @@map("requisitions")
}

model RequisitionItem {
  id            String   @id @default(uuid()) @db.UniqueIdentifier
  requisitionId String   @db.UniqueIdentifier
  itemId        String?  @db.UniqueIdentifier
  description   String   @db.NVarChar(500)
  quantity      Decimal  @db.Decimal(15, 4)
  unit          String   @db.NVarChar(20)
  estimatedPrice Decimal @db.Decimal(15, 2)
  totalPrice    Decimal  @db.Decimal(15, 2)
  accountingCode String? @db.NVarChar(50)
  notes         String?  @db.NVarChar(Max)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requisition Requisition @relation(fields: [requisitionId], references: [id])

  @@map("requisition_items")
}

// ============================================================
// PEDIDOS DE COMPRA (OC)
// ============================================================

model PurchaseOrder {
  id              String              @id @default(uuid()) @db.UniqueIdentifier
  number          String              @unique @db.NVarChar(20) // OC-2026-000001
  companyId       String              @db.UniqueIdentifier
  branchId        String              @db.UniqueIdentifier
  costCenterId    String              @db.UniqueIdentifier
  buyerId         String              @db.UniqueIdentifier
  supplierId      String              @db.UniqueIdentifier
  requisitionId   String?             @db.UniqueIdentifier
  status          PurchaseOrderStatus @default(DRAFT)
  paymentTerms    String?             @db.NVarChar(255)
  deliveryAddress String?             @db.NVarChar(500)
  expectedDelivery DateTime?
  totalAmount     Decimal             @db.Decimal(15, 2) @default(0)
  notes           String?             @db.NVarChar(Max)
  erpOcId         String?             @db.NVarChar(50) // ID no ERP após integração
  integratedAt    DateTime?
  submittedAt     DateTime?
  approvedAt      DateTime?
  sentToSupplierAt DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  buyer    User            @relation(fields: [buyerId], references: [id])
  supplier Supplier        @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]
  approvals ApprovalFlow[]
  receivings Receiving[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(uuid()) @db.UniqueIdentifier
  purchaseOrderId String   @db.UniqueIdentifier
  itemId          String?  @db.UniqueIdentifier
  description     String   @db.NVarChar(500)
  quantity        Decimal  @db.Decimal(15, 4)
  unit            String   @db.NVarChar(20)
  unitPrice       Decimal  @db.Decimal(15, 2)
  totalPrice      Decimal  @db.Decimal(15, 2)
  accountingCode  String?  @db.NVarChar(50)
  receivedQty     Decimal  @db.Decimal(15, 4) @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_order_items")
}

// ============================================================
// FLUXO DE APROVAÇÃO
// ============================================================

model ApprovalFlow {
  id              String         @id @default(uuid()) @db.UniqueIdentifier
  entityType      String         @db.NVarChar(50) // REQUISITION | PURCHASE_ORDER
  entityId        String         @db.UniqueIdentifier
  approverId      String         @db.UniqueIdentifier
  order           Int
  status          ApprovalStatus @default(PENDING)
  decidedAt       DateTime?
  comments        String?        @db.NVarChar(Max)
  companyId       String         @db.UniqueIdentifier
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  requisition   Requisition?   @relation(fields: [entityId], references: [id], map: "approval_flow_req_fk")
  purchaseOrder PurchaseOrder? @relation(fields: [entityId], references: [id], map: "approval_flow_oc_fk")

  @@map("approval_flows")
}

// ============================================================
// RECEBIMENTO
// ============================================================

model Receiving {
  id              String          @id @default(uuid()) @db.UniqueIdentifier
  number          String          @unique @db.NVarChar(20) // REC-2026-000001
  purchaseOrderId String          @db.UniqueIdentifier
  companyId       String          @db.UniqueIdentifier
  receivedById    String          @db.UniqueIdentifier
  status          ReceivingStatus @default(DRAFT)
  receivedAt      DateTime
  notes           String?         @db.NVarChar(Max)
  divergenceNotes String?         @db.NVarChar(Max)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  purchaseOrder PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  items         ReceivingItem[]

  @@map("receivings")
}

model ReceivingItem {
  id              String   @id @default(uuid()) @db.UniqueIdentifier
  receivingId     String   @db.UniqueIdentifier
  purchaseOrderItemId String @db.UniqueIdentifier
  receivedQty     Decimal  @db.Decimal(15, 4)
  acceptedQty     Decimal  @db.Decimal(15, 4)
  rejectedQty     Decimal  @db.Decimal(15, 4) @default(0)
  rejectionReason String?  @db.NVarChar(Max)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  receiving Receiving @relation(fields: [receivingId], references: [id])

  @@map("receiving_items")
}

// ============================================================
// AUDITORIA
// ============================================================

model AuditLog {
  id         String   @id @default(uuid()) @db.UniqueIdentifier
  companyId  String   @db.UniqueIdentifier
  userId     String   @db.UniqueIdentifier
  action     String   @db.NVarChar(100) // CREATE | UPDATE | DELETE | APPROVE | REJECT
  entityType String   @db.NVarChar(100)
  entityId   String   @db.UniqueIdentifier
  before     String?  @db.NVarChar(Max) // JSON snapshot
  after      String?  @db.NVarChar(Max) // JSON snapshot
  ipAddress  String?  @db.NVarChar(50)
  userAgent  String?  @db.NVarChar(500)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// NUMERAÇÃO DE DOCUMENTOS
// ============================================================

model DocumentSequence {
  id        String   @id @default(uuid()) @db.UniqueIdentifier
  companyId String   @db.UniqueIdentifier
  type      String   @db.NVarChar(20) // REQ | OC | REC | DOC
  year      Int
  lastSeq   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([companyId, type, year])
  @@map("document_sequences")
}
