// ============================================================
// P2P_DB — Schema Prisma (SQL Server)
//
// ARQUITETURA DE DADOS:
// - Dados de REFERÊNCIA do ERP (filiais, CCs, fornecedores, itens, contas,
//   rateios) NÃO são copiados para o P2P. São lidos ao vivo das views
//   v_p2p_* (cross-database, mesmo servidor).
// - Dados TRANSACIONAIS nascem e vivem no P2P_DB. Guardam o CÓDIGO do ERP
//   (string) + um SNAPSHOT do nome/descrição no momento da criação, para
//   o histórico não quebrar se o ERP mudar depois.
// - Integração: o P2P GRAVA suas OCs/SVs aprovadas no ERP (COMPRAS,
//   COMPRAS_CONSUMIVEL, CTB_SOLICITACAO_VERBA). Fluxo de dados P2P -> ERP.
//
// NOTAS SQL Server:
// - Enums não suportados pelo Prisma: status/tipo são String validados na app.
// - onDelete/onUpdate = NoAction em todas as relações (múltiplos cascade paths).
// - Numeração: SQL Server SEQUENCE (ver DocumentSequence).
//
// Valores válidos (constantes em src/common/enums.ts):
//   UserProfile:          ADMIN | MANAGER | OPERATOR | REVIEWER
//   UserStatus:           ACTIVE | INACTIVE | PENDING_SETUP
//   RequisitionNfType:    SEM_NF | NF_FUTURA | NF_EXISTENTE
//   RequisitionStatus:    DRAFT | SUBMITTED | IN_APPROVAL | APPROVED | REJECTED | CONVERTED | CANCELLED
//   PurchaseOrderStatus:  DRAFT | IN_APPROVAL | APPROVED | SENT_TO_SUPPLIER |
//                         PARTIALLY_RECEIVED | FULLY_RECEIVED | PENDING_ERP | INTEGRATED | CANCELLED
//   FundRequestStatus:    DRAFT | IN_APPROVAL | APPROVED | REJECTED | PENDING_ERP | INTEGRATED | CANCELLED
//   ApprovalStepStatus:   PENDING | APPROVED | REJECTED
//   ReceivingStatus:      DRAFT | CONFIRMED | DIVERGENT | CANCELLED
//   ApprovalEntityType:   REQUISITION | PURCHASE_ORDER | FUND_REQUEST
//   NotificationType:     APPROVAL_REQUIRED | APPROVED | REJECTED | OVERDUE | BUDGET_ALERT | GENERAL
//   IntegrationLogStatus: SUCCESS | PARTIAL | FAILED
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

// ============================================================
// EMPRESAS (dado próprio do P2P — 2 registros: Guess e HRG3)
// ============================================================

model Company {
  id        String    @id @default(uuid()) @db.UniqueIdentifier
  code      String    @unique @db.NVarChar(20)  // GUESS | HRG3 (casa com coluna empresa das views)
  name      String    @db.NVarChar(255)
  cnpj      String?   @db.NVarChar(18)
  /**
   * Raízes de CNPJ adicionais que pertencem a esta empresa.
   * JSON array de strings de 8 dígitos. Necessário porque uma mesma
   * empresa do grupo pode ter múltiplas raízes (ex.: Guess tem
   * 09391614, 17809524, 11850562). Usado pra rotear NFes da Qive
   * pra company certa pelo CNPJ do destinatário.
   */
  cnpjRaizes String?  @db.NVarChar(500)
  erpDbName String    @db.NVarChar(100)         // GUESS_PRODUCAO | DB_HRG3
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users                 UserCompany[]
  requisitions          Requisition[]
  purchaseOrders        PurchaseOrder[]
  fundRequests          FundRequest[]
  budgetEntries         BudgetEntry[]
  integrationLogs       IntegrationLog[]
  teamBranchRateios     TeamBranchRateio[]
  teamCostCenterRateios TeamCostCenterRateio[]
  settings              SystemSetting[]
  fiscalItemRequests    FiscalItemRequest[]
  erpConfig             CompanyErpConfig?
  branchAssignments     UserBranchAssignment[]
  branchExtensions      BranchExtension[]
  fiscalDocuments       FiscalDocument[]
  fiscalDocumentSyncStates FiscalDocumentSyncState[]

  @@map("companies")
}

// ============================================================
// Configuração da integração com o ERP Linx, por empresa.
// Cada empresa pode usar TIPO_COMPRA, CTB_TIPO_OPERACAO e NATUREZA_ENTRADA
// diferentes (Guess e HRG3 têm cadastros distintos no Linx). Aqui ficam
// os defaults que o P2P aplica quando o solicitante/fiscal não sobrescreve.
// SMTP também é por empresa: cada uma pode usar seu próprio servidor.
// ============================================================
model CompanyErpConfig {
  companyId                   String   @id @db.UniqueIdentifier
  codTransacao                String   @db.NVarChar(25)   // 'COMPRAS_003'
  tabelaFilha                 String   @db.NVarChar(25)   // 'COMPRAS_CONSUMIVEL'
  tipoCompraDefault           String   @db.NVarChar(25)   // ex.: 'COMPRA DIVERSAS'
  ctbTipoOperacaoDefault      Int                          // ex.: 202
  naturezaEntradaDefault      String   @db.NVarChar(15)   // ex.: '202.01'
  moeda                       String   @default("R$") @db.NVarChar(6)
  transportadoraPadrao        String?  @db.NVarChar(25)   // nome (varchar 25 no ERP)
  smtpHost                    String?  @db.NVarChar(255)
  smtpPort                    Int?
  smtpUser                    String?  @db.NVarChar(255)
  smtpPassword                String?  @db.NVarChar(500)  // criptografado seria ideal; por ora plain
  smtpSecure                  Boolean  @default(false)
  smtpFrom                    String?  @db.NVarChar(255)
  smtpFromName                String?  @db.NVarChar(255)
  emailSubjectTemplate        String?  @db.NVarChar(255)
  emailBodyTemplate           String?  @db.NVarChar(Max)
  // Pedidos de Produto Acabado (PA) — fluxo paralelo. O diretor da marca
  // é o aprovador único por empresa. Quando o negócio evoluir para
  // alçada por valor (cadeia), substituir esta coluna por um vínculo
  // com TeamApprovalLevel com escopo PA (ver Rodada 8 / dívida 6.2).
  paApproverUserId            String?  @db.UniqueIdentifier
  /**
   * Time autorizado a reagendar entregas de pedidos PA (Compras).
   * O ERP não preenche REQUERIDO_POR de PA, então a permissão é por time
   * configurado aqui (mais ADMIN, que sempre pode).
   */
  paReschedulerTeamId         String?  @db.UniqueIdentifier
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  company           Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  paApprover        User?   @relation("PaApprover", fields: [paApproverUserId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  paReschedulerTeam Team?   @relation("PaReschedulerTeam", fields: [paReschedulerTeamId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("company_erp_configs")
}

// ============================================================
// PARÂMETROS DA PLATAFORMA — configuráveis pelo Administrador
// Chave/valor por empresa (cada empresa tem seus próprios valores).
// Ex.: receiving.divergence_tolerance_pct
// ============================================================

model SystemSetting {
  id            String   @id @default(uuid()) @db.UniqueIdentifier
  companyId     String   @db.UniqueIdentifier
  key           String   @db.NVarChar(80)
  value         String   @db.NVarChar(Max)
  updatedById   String?  @db.UniqueIdentifier
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  updatedBy User?   @relation(fields: [updatedById], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@unique([companyId, key])
  @@map("system_settings")
}

// ============================================================
// PENDÊNCIAS FISCAIS DE ITEM
// Quando o item da requisição não está vinculado ao fornecedor no Linx:
//   LINK — item existe no catálogo, falta vincular ao fornecedor
//   NEW  — item não existe; equipe Fiscal cadastra no Linx
// Resolvida pela equipe Fiscal (Team.isFiscal); ao aprovar, o P2P grava
// o vínculo / o item novo no Linx.
// ============================================================

model FiscalItemRequest {
  id              String    @id @default(uuid()) @db.UniqueIdentifier
  companyId       String    @db.UniqueIdentifier
  type            String    @db.NVarChar(10)   // LINK | NEW
  status          String    @default("PENDING") @db.NVarChar(15) // PENDING | APPROVED | REJECTED
  supplierErpCode String    @db.NVarChar(50)
  supplierName    String    @db.NVarChar(255)
  itemErpCode     String?   @db.NVarChar(50)   // LINK: item existente; NEW: definido na aprovação
  itemDescription String    @db.NVarChar(255)
  unit            String?   @db.NVarChar(20)
  requestedById   String    @db.UniqueIdentifier
  resolvedById    String?   @db.UniqueIdentifier
  resolvedAt      DateTime?
  rejectionReason String?   @db.NVarChar(Max)
  notes           String?   @db.NVarChar(Max)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company     Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  requestedBy User    @relation("fiscalRequester", fields: [requestedById], references: [id], onUpdate: NoAction, onDelete: NoAction)
  resolvedBy  User?   @relation("fiscalResolver", fields: [resolvedById], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([companyId, status])
  @@map("fiscal_item_requests")
}

// ============================================================
// Documentos fiscais (NFe / NFSe / CTe) baixados da Qive (Arquivei).
// Por enquanto vamos só listar e VINCULAR manualmente ao PC; o
// lançamento no Linx e a manifestação ficam pra fase futura
// (robô de escrituração automática que a TI HRG3 já tem em uso).
// ============================================================

model FiscalDocument {
  id              String    @id @default(uuid()) @db.UniqueIdentifier
  companyId       String    @db.UniqueIdentifier
  /** NFe | NFSe | CTe — começamos só com NFe. */
  type            String    @db.NVarChar(10)
  /** Chave SEFAZ — 44 chars (NFe/CTe) ou identificador da NFSe. */
  accessKey       String    @unique @db.NVarChar(80)
  /** Cursor da Qive no momento do fetch — pra rastreabilidade. */
  qiveCursor      Int?
  // ─── Emitente (fornecedor externo da nossa perspectiva) ───
  supplierCnpj    String    @db.NVarChar(14)
  supplierName    String    @db.NVarChar(255)
  // ─── Destinatário (uma das nossas filiais) ───
  destCnpj        String    @db.NVarChar(14)
  destName        String?   @db.NVarChar(255)
  // ─── Identificação da NF ───
  numero          String    @db.NVarChar(20)
  serie           String?   @db.NVarChar(10)
  natOp           String?   @db.NVarChar(255)
  valorTotal      Decimal   @db.Decimal(15, 2)
  emissao         DateTime
  /**
   * Status:
   *  - PENDING — recém-baixada, sem ação
   *  - LINKED — operador vinculou ao PC (purchaseOrderId preenchido)
   *  - IGNORED — operador marcou que não vai virar PC (transferência
   *              interna, devolução, etc.)
   *  - INTERNAL — emitente é CNPJ próprio da empresa (auto-classificada
   *               como transferência interna; pula da lista padrão)
   */
  status          String    @default("PENDING") @db.NVarChar(15)
  purchaseOrderId String?   @db.UniqueIdentifier
  /**
   * Vínculo com pedido legado (Linx, pré-P2P). Quando setado, a NF
   * está associada a um PEDIDO da tabela COMPRAS no Linx mesmo —
   * não tem PurchaseOrder no P2P. Usado pela tela de Pedidos Legados.
   */
  legacyPedido    String?   @db.NVarChar(20)
  legacyCompanyId String?   @db.UniqueIdentifier
  linkedById      String?   @db.UniqueIdentifier
  linkedAt        DateTime?
  notes           String?   @db.NVarChar(Max)
  /**
   * XML completo da NFe em base64 (mesmo que a Qive devolve).
   * Permite re-parse / re-extração sem precisar voltar pra Qive.
   * Median ~5-10KB por NFe.
   */
  rawXmlBase64    String    @db.NVarChar(Max)
  /**
   * Itens parseados do XML — JSON serializado pra exibir sem reparse.
   * Estrutura: [{ cProd, xProd, ncm, cfop, qCom, vUnCom, vProd, uCom }, ...]
   */
  itemsJson       String?   @db.NVarChar(Max)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  company       Company        @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  purchaseOrder PurchaseOrder? @relation("FiscalDocumentLinked", fields: [purchaseOrderId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  linkedBy      User?          @relation("FiscalDocumentLinker", fields: [linkedById], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([companyId, status, emissao])
  @@index([supplierCnpj])
  @@index([purchaseOrderId])
  @@map("fiscal_documents")
}

/**
 * Cursor da última sincronização da Qive por empresa — permite o cron
 * retomar de onde parou. Uma linha por (companyId, role).
 */
model FiscalDocumentSyncState {
  id          String    @id @default(uuid()) @db.UniqueIdentifier
  companyId   String    @db.UniqueIdentifier
  /** role da Qive: received | emitted | transporter | authorized */
  role        String    @db.NVarChar(20)
  /** Cursor da v1 (legado) — não usamos mais, mantemos pra compat. */
  lastCursor  Int       @default(0)
  /** Paginator da v2 — string opaca devolvida pela API a cada página. */
  lastPaginator String? @db.NVarChar(1000)
  lastSyncAt  DateTime?
  lastError   String?   @db.NVarChar(Max)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@unique([companyId, role])
  @@map("fiscal_document_sync_states")
}

// ============================================================
// EQUIPES — escopo de operação parametrizável
// Uma equipe pode operar em várias empresas. Define quais rateios de
// filial e de centro de custo seus membros podem usar e enxergar.
// ============================================================

model Team {
  id        String    @id @default(uuid()) @db.UniqueIdentifier
  name      String    @db.NVarChar(150)
  managerId String?   @db.UniqueIdentifier  // gestor — visibilidade + dono do orçamento
  active    Boolean   @default(true)
  isFiscal  Boolean   @default(false)       // equipe Fiscal — resolve pendências de item
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  manager           User?  @relation("teamManager", fields: [managerId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  members           User[] @relation("teamMembers")
  branchRateios     TeamBranchRateio[]
  costCenterRateios TeamCostCenterRateio[]
  approvalLevels    TeamApprovalLevel[]
  requisitions      Requisition[]
  paReschedulerFor  CompanyErpConfig[] @relation("PaReschedulerTeam")
  moduleAccess      TeamModuleAccess[]

  @@map("teams")
}

// Módulos extras liberados para uma equipe (além do que o perfil já vê).
// Ex.: equipe de Compras com OPERATORs ganha o módulo PA; equipe Fiscal
// com OPERATORs ganha FISCAL_QUEUE. Admin/Manager continuam vendo os
// módulos restritos pelo perfil.
model TeamModuleAccess {
  teamId    String   @db.UniqueIdentifier
  module    String   @db.NVarChar(40)   // PA | FISCAL_QUEUE | REPORTS | RECEIVING | APPROVALS
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onUpdate: NoAction, onDelete: Cascade)

  @@id([teamId, module])
  @@map("team_module_access")
}

// ============================================================
// CADEIA DE APROVAÇÃO POR EQUIPE
// Cada equipe define sua própria cadeia sequencial de níveis
// (ex.: Coordenador -> Gestor -> Diretor). Cada nível tem um
// aprovador e uma alçada (maxAmount). Cadeia vazia = auto-aprovado.
// ============================================================

/**
 * Dados extras de filiais que o P2P guarda além do que vem da view
 * `v_p2p_branches` (que reflete o ERP). Hoje, só o e-mail da filial —
 * usado para enviar link de recuperação de senha para vendedores e
 * para notificações relacionadas à loja.
 *
 * A chave é (companyId, branchErpCode). Filial sem registro aqui tem
 * email implicitamente nulo (recuperação por e-mail desabilitada).
 */
model BranchExtension {
  companyId     String   @db.UniqueIdentifier
  branchErpCode String   @db.NVarChar(20)
  email         String?  @db.NVarChar(255)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@id([companyId, branchErpCode])
  @@map("branch_extensions")
}

/**
 * Cargos (positions) gerenciados pelo Admin — usados pela cadeia de
 * aprovação dinâmica (TeamApprovalLevel.requiredPositionId).
 */
model Position {
  id        String    @id @default(uuid()) @db.UniqueIdentifier
  code      String    @unique @db.NVarChar(40)  // SUPERVISOR | DIRETOR | etc
  name      String    @db.NVarChar(150)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users          User[]
  approvalLevels TeamApprovalLevel[]

  @@map("positions")
}

/**
 * Atribuição N:N de usuário a filiais. Usado pela cadeia de aprovação
 * com escopo por filial (ex.: "Supervisor da filial 0102"). O cargo
 * vem do User.positionId — esta tabela só amarra pessoa↔filial.
 */
model UserBranchAssignment {
  userId        String   @db.UniqueIdentifier
  companyId     String   @db.UniqueIdentifier
  branchErpCode String   @db.NVarChar(20)
  createdAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@id([userId, companyId, branchErpCode])
  @@map("user_branch_assignments")
}

/**
 * Token de definição/recuperação de senha (envio por e-mail).
 * `tokenHash` é SHA-256 do token enviado — o token bruto só existe no link.
 * Usado UMA VEZ — após consumo, marcamos usedAt.
 */
model PasswordSetupToken {
  id        String   @id @default(uuid()) @db.UniqueIdentifier
  userId    String   @db.UniqueIdentifier
  tokenHash String   @unique @db.NVarChar(64)
  purpose   String   @db.NVarChar(20)  // 'SETUP' | 'RESET'
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: Cascade)

  @@index([userId])
  @@map("password_setup_tokens")
}

model TeamApprovalLevel {
  id         String   @id @default(uuid()) @db.UniqueIdentifier
  teamId     String   @db.UniqueIdentifier
  level      Int                            // 1 = primeiro a aprovar
  name       String   @db.NVarChar(50)      // Coordenador | Gestor | Diretor...
  // Modos de aprovação (mutuamente exclusivos — UI valida):
  //   1) approverId preenchido           → pessoa fixa
  //   2) requiredPositionId, scopeByBranch=false → qualquer usuário com aquele cargo
  //   3) requiredPositionId, scopeByBranch=true  → qualquer usuário com aquele
  //      cargo atribuído à filial da requisição
  approverId         String?  @db.UniqueIdentifier
  requiredPositionId String?  @db.UniqueIdentifier
  scopeByBranch      Boolean  @default(false)
  maxAmount  Decimal? @db.Decimal(15, 2)    // alçada do nível (null = sem limite)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  team             Team           @relation(fields: [teamId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  approver         User?          @relation("levelApprover", fields: [approverId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  requiredPosition Position?      @relation(fields: [requiredPositionId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  approvalSteps    ApprovalStep[]

  @@unique([teamId, level])
  @@map("team_approval_levels")
}

// Rateios de filial que a equipe pode usar, por empresa
model TeamBranchRateio {
  id               String @id @default(uuid()) @db.UniqueIdentifier
  teamId           String @db.UniqueIdentifier
  companyId        String @db.UniqueIdentifier
  branchRateioCode String @db.NVarChar(20)

  team    Team    @relation(fields: [teamId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  company Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@unique([teamId, companyId, branchRateioCode])
  @@map("team_branch_rateios")
}

// Rateios de centro de custo que a equipe pode usar, por empresa
model TeamCostCenterRateio {
  id                   String @id @default(uuid()) @db.UniqueIdentifier
  teamId               String @db.UniqueIdentifier
  companyId            String @db.UniqueIdentifier
  costCenterRateioCode String @db.NVarChar(20)

  team    Team    @relation(fields: [teamId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  company Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@unique([teamId, companyId, costCenterRateioCode])
  @@map("team_cost_center_rateios")
}

// ============================================================
// USUÁRIOS (dado próprio do P2P — criados via JIT no login LDAP)
// ============================================================

model User {
  id            String    @id @default(uuid()) @db.UniqueIdentifier
  // Login AD (sAMAccountName) — opcional pra suportar usuários locais
  // (supervisores e vendedores que não estão no AD).
  adUsername    String?   @unique @db.NVarChar(255)
  // Username P2P-local — definido pelo Admin para supervisores e demais
  // usuários LOCAL não-vendedores. Mutuamente exclusivo com adUsername.
  username      String?   @unique @db.NVarChar(60)
  email         String    @unique @db.NVarChar(255)  // corporativo, obrigatório (RN-USR-01); sincronizado do AD
  name          String    @db.NVarChar(255)
  profile       String    @db.NVarChar(20)
  status        String    @default("PENDING_SETUP") @db.NVarChar(20)
  teamId        String?   @db.UniqueIdentifier  // equipe — escopo de operação
  // Permissão de alternar entre PROD e HML pela topbar. Admin sempre tem.
  // Para usuários não-admin, o Admin libera caso a caso (ex.: equipe de QA).
  canSwitchEnv  Boolean   @default(false)
  // Auth local — para usuários fora do AD (supervisores via link de e-mail,
  // vendedores via CPF). passwordHash é bcrypt; passwordSetAt marca quando
  // foi definida (null = ainda não definiu).
  loginType     String    @default("AD") @db.NVarChar(10) // 'AD' | 'LOCAL'
  cpf           String?   @unique @db.NVarChar(11)        // só dígitos
  passwordHash  String?   @db.NVarChar(255)
  passwordSetAt DateTime?
  /**
   * Proteção contra força bruta: contador de tentativas seguidas que
   * falharam (zera em login bem-sucedido). Quando `lockedUntil` está no
   * futuro, o login é rejeitado mesmo com credenciais certas — até
   * passar a janela. Janelas crescentes: 5 falhas → 15min, 10 → 1h,
   * 15 → 24h (encerra o burst e dificulta credential stuffing).
   */
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  lastFailedLoginAt   DateTime?
  // Cargo (Position) — usado pela cadeia de aprovação dinâmica.
  positionId    String?   @db.UniqueIdentifier
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  team                Team?           @relation("teamMembers", fields: [teamId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  managedTeams        Team[]          @relation("teamManager")
  approvalLevels      TeamApprovalLevel[] @relation("levelApprover")
  companies           UserCompany[]
  delegationsGiven    Delegation[]    @relation("delegator")
  delegationsReceived Delegation[]    @relation("delegate")
  requisitions        Requisition[]
  purchaseOrders      PurchaseOrder[]
  fundRequests        FundRequest[]
  assignedSteps       ApprovalStep[]  @relation("stepApprover")
  decidedSteps        ApprovalStep[]  @relation("stepDecider")
  receivings          Receiving[]
  notifications       Notification[]
  updatedSettings     SystemSetting[]
  fiscalRequests      FiscalItemRequest[] @relation("fiscalRequester")
  fiscalDocumentsLinked FiscalDocument[]  @relation("FiscalDocumentLinker")
  fiscalResolutions   FiscalItemRequest[] @relation("fiscalResolver")
  createdQuotations   Quotation[]         @relation("quotationCreatedBy")
  selectedQuotations  Quotation[]         @relation("quotationSelectedBy")
  paApproverFor       CompanyErpConfig[] @relation("PaApprover")
  paDeliveryChanges   PaDeliveryChange[] @relation("PaDeliveryChangeUser")
  position            Position?          @relation(fields: [positionId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  branchAssignments   UserBranchAssignment[]
  passwordTokens      PasswordSetupToken[]

  @@map("users")
}

model UserCompany {
  id        String   @id @default(uuid()) @db.UniqueIdentifier
  userId    String   @db.UniqueIdentifier
  companyId String   @db.UniqueIdentifier
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  company Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@unique([userId, companyId])
  @@map("user_companies")
}

model Delegation {
  id          String    @id @default(uuid()) @db.UniqueIdentifier
  delegatorId String    @db.UniqueIdentifier
  delegateId  String    @db.UniqueIdentifier
  startsAt    DateTime
  endsAt      DateTime
  reason      String?   @db.NVarChar(500)
  createdById String    @db.UniqueIdentifier
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  delegator User @relation("delegator", fields: [delegatorId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  delegate  User @relation("delegate", fields: [delegateId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("delegations")
}

// ============================================================
// ORÇAMENTO (MVP: empresa + filial + CC + ano + mês)
// branchErpCode / costCenterErpCode = códigos do ERP (lidos das views)
// ============================================================

model BudgetEntry {
  id               String   @id @default(uuid()) @db.UniqueIdentifier
  companyId        String   @db.UniqueIdentifier
  branchErpCode    String   @db.NVarChar(50)
  costCenterErpCode String  @db.NVarChar(50)
  year             Int
  month            Int
  amountBudgeted   Decimal  @db.Decimal(15, 2)
  amountCommitted  Decimal  @default(0) @db.Decimal(15, 2)
  amountConsumed   Decimal  @default(0) @db.Decimal(15, 2)
  importedById     String?  @db.UniqueIdentifier
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@unique([companyId, branchErpCode, costCenterErpCode, year, month])
  @@index([companyId, year])
  @@map("budget_entries")
}

// ============================================================
// REQUISIÇÕES — porta de entrada do P2P
// tipoNotaFiscal decide o que a requisição gera ao ser aprovada:
//   SEM_NF       -> Solicitacao de Verba
//   NF_FUTURA    -> Pedido de Compra + Solicitacao de Verba (adiantamento)
//   NF_EXISTENTE -> Pedido de Compra
// Códigos do ERP guardados como string + snapshot do nome.
// ============================================================

model Requisition {
  id               String    @id @default(uuid()) @db.UniqueIdentifier
  number           String    @unique @db.NVarChar(20)
  companyId        String    @db.UniqueIdentifier
  branchErpCode    String    @db.NVarChar(50)   // filial principal (cabeçalho)
  branchName       String    @db.NVarChar(255)  // snapshot
  /**
   * Código do fornecedor no ERP. Nullable quando o solicitante registra
   * um fornecedor externo (CNPJ ainda não cadastrado no Linx). Nesse
   * caso, `needsSupplierErpCreation = true` e os campos `supplier*` extras
   * (CNPJ, endereço, CNAE, etc.) ficam preenchidos para que o cadastro
   * automático no ERP seja feito ao aprovar.
   */
  supplierErpCode  String?   @db.NVarChar(50)
  supplierName     String    @db.NVarChar(255)  // razão social
  supplierCnpj     String?   @db.NVarChar(14)   // CNPJ só dígitos
  supplierFantasia    String? @db.NVarChar(200)
  supplierEmail       String? @db.NVarChar(200)
  supplierTelefone    String? @db.NVarChar(50)
  supplierLogradouro  String? @db.NVarChar(200)
  supplierNumero      String? @db.NVarChar(20)
  supplierBairro      String? @db.NVarChar(100)
  supplierCidade      String? @db.NVarChar(100)
  supplierUf          String? @db.NVarChar(2)
  supplierCep         String? @db.NVarChar(10)
  supplierCnae        String? @db.NVarChar(200)
  /**
   * Marca que o fornecedor atual da requisição não está no ERP — vai
   * ser criado automaticamente no Linx quando a requisição for aprovada.
   * Substitui o antigo `winningQuotationNeedsErp` (que tratava só o caso
   * de cotação vencedora — agora unifica os dois caminhos).
   */
  needsSupplierErpCreation Boolean @default(false)
  requesterId      String    @db.UniqueIdentifier
  teamId           String?   @db.UniqueIdentifier  // equipe do solicitante (visibilidade)
  title            String    @db.NVarChar(500)
  justification    String?   @db.NVarChar(Max)
  tipoNotaFiscal   String    @db.NVarChar(15)   // SEM_NF | NF_FUTURA | NF_EXISTENTE
  status           String    @default("DRAFT") @db.NVarChar(20)
  totalAmount      Decimal   @default(0) @db.Decimal(15, 2)
  // Condição de pagamento — default herdado do fornecedor (PRD 7.1)
  paymentConditionCode String? @db.NVarChar(20)
  paymentConditionDesc String? @db.NVarChar(100)
  recurring        Boolean   @default(false)    // requisição recorrente
  recurrenceMonths Int?                         // por quantos meses se repete
  // PRD RN-REQ-03: cron diário gera requisição filha (DRAFT) a cada
  // `recurrenceMonths` meses a partir desta. `recurrenceParentId`
  // aponta para a original; `nextRecurrenceAt` é setado ao aprovar e
  // atualizado a cada geração.
  recurrenceParentId String? @db.UniqueIdentifier
  nextRecurrenceAt   DateTime?
  contractRef      String?   @db.NVarChar(100)  // contrato vinculado (quando aplicável)
  // Contagem em cache de anexos com kind=QUOTATION — recalculada pelo
  // AttachmentsService a cada upload/delete. A fonte da verdade pro
  // submit é o `attachment.count({kind:'QUOTATION'})`, mas mantemos
  // este campo pra queries de listagem não precisarem fazer join.
  quotationsCount  Int       @default(0)
  /**
   * Dispensa de cotação (RN-REQ-02 — exceção). Quando o solicitante
   * alega motivo aplicável (recorrente, único fornecedor, etc.), o
   * submit pula a checagem de 3 cotações mas o motivo + justificativa
   * ficam visíveis pro aprovador, que decide se aceita.
   * Valores em `QuotationWaiverReason` (TS const). Quando null, a
   * regra padrão de cotações vale.
   */
  quotationWaiverReason String?  @db.NVarChar(30)
  quotationWaiverNote   String?  @db.NVarChar(Max)
  quotationWaiverAt     DateTime?
  /**
   * Cotação vencedora — quando o aprovador escolheu uma proposta no
   * lugar dos dados originais (os campos `supplier*` já foram sobrescritos
   * com os dados da cotação no momento da seleção). A marca de "precisa
   * cadastrar no ERP" mora em `needsSupplierErpCreation` (campo unificado).
   */
  winningQuotationId       String?   @db.UniqueIdentifier
  /**
   * Snapshot da proposta original do solicitante (supplier + items + total)
   * gravado no momento em que o aprovador seleciona a PRIMEIRA cotação
   * vencedora. Permite restaurar a req ao estado original via clearWinner
   * quando o aprovador muda de ideia. JSON serializado.
   */
  originalProposalSnapshot String?   @db.NVarChar(Max)
  // Classificação Linx — preenchida pelo solicitante (tipoCompra) e pelo
  // fiscal (ctbTipoOperacao + naturezaEntrada) antes da conversão em PC.
  tipoCompra       String?   @db.NVarChar(25)
  ctbTipoOperacao  Int?
  naturezaEntrada  String?   @db.NVarChar(15)
  currentTierLevel Int?
  submittedAt      DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?   @db.NVarChar(Max)
  /**
   * Revisão: aprovador pode mandar a requisição de volta com motivo.
   * Status vira REVISION; requisitante edita e re-submete. `lastEditReason`
   * é preenchido tanto pelo requisitante (auto-edição) quanto pelo aprovador
   * (request-revision).
   */
  revisionReason       String?   @db.NVarChar(Max)
  revisionRequestedAt  DateTime?
  revisionRequestedById String?  @db.UniqueIdentifier
  lastEditReason       String?   @db.NVarChar(Max)
  lastEditedAt         DateTime?
  lastEditedById       String?   @db.UniqueIdentifier
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  company       Company           @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  requester     User              @relation(fields: [requesterId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  team           Team?             @relation(fields: [teamId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  items          RequisitionItem[]
  approvalSteps  ApprovalStep[]
  purchaseOrders PurchaseOrder[]
  fundRequest    FundRequest?
  attachments    Attachment[]
  quotations     Quotation[]
  recurrenceParent   Requisition?  @relation("ReqRecurrence", fields: [recurrenceParentId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  recurrenceChildren Requisition[] @relation("ReqRecurrence")

  @@index([companyId, status])
  @@index([requesterId, status])
  @@index([teamId, status])
  // Cobre o findAll mais comum: WHERE companyId+teamId ORDER BY createdAt DESC.
  @@index([companyId, teamId, createdAt(sort: Desc)])
  // Cobre listagens "minhas" (ADMIN, sem teamId).
  @@index([companyId, createdAt(sort: Desc)])
  @@map("requisitions")
}

model RequisitionItem {
  id                   String   @id @default(uuid()) @db.UniqueIdentifier
  requisitionId        String   @db.UniqueIdentifier
  itemErpCode          String?  @db.NVarChar(50)   // null = item livre
  itemDescription      String   @db.NVarChar(500)  // snapshot ou texto livre
  quantity             Decimal  @db.Decimal(15, 4)
  unit                 String   @db.NVarChar(20)
  estimatedPrice       Decimal  @db.Decimal(15, 2)
  totalPrice           Decimal  @db.Decimal(15, 2)
  accountingAccount    String   @db.NVarChar(20)   // CONTA_CONTABIL
  accountName          String?  @db.NVarChar(255)  // snapshot
  branchRateioCode     String   @db.NVarChar(20)   // template RATEIO_FILIAL
  branchRateioDesc     String?  @db.NVarChar(100)  // snapshot
  costCenterRateioCode String   @db.NVarChar(20)   // template RATEIO_CENTRO_CUSTO
  costCenterRateioDesc String?  @db.NVarChar(100)  // snapshot
  notes                String?  @db.NVarChar(Max)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  requisition Requisition             @relation(fields: [requisitionId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  rateios     RequisitionItemRateio[]

  @@index([requisitionId])
  @@map("requisition_items")
}

// Snapshot do rateio do item — congelado na criação (RN-RAT-02).
// Cada item gera N linhas BRANCH (somam 100%) e N linhas COST_CENTER.
// Alterações futuras nos templates do ERP não afetam o que foi congelado.
model RequisitionItemRateio {
  id                String   @id @default(uuid()) @db.UniqueIdentifier
  requisitionItemId String   @db.UniqueIdentifier
  kind              String   @db.NVarChar(15)  // BRANCH | COST_CENTER
  rateioCode        String   @db.NVarChar(20)  // código do template de origem
  targetCode        String   @db.NVarChar(20)  // filial (BRANCH) ou CC (COST_CENTER)
  branchCode        String?  @db.NVarChar(20)  // filial da linha de CC, quando houver
  percentage        Decimal  @db.Decimal(9, 4)
  amount            Decimal  @db.Decimal(15, 2) // valor rateado congelado
  createdAt         DateTime @default(now())

  requisitionItem RequisitionItem @relation(fields: [requisitionItemId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([requisitionItemId])
  @@index([kind, targetCode])
  @@map("requisition_item_rateios")
}

// ============================================================
// PEDIDOS DE COMPRA (PC) — 1:1 com Requisição
// Espelha COMPRAS + COMPRAS_CONSUMIVEL do ERP
// ============================================================

model PurchaseOrder {
  id               String    @id @default(uuid()) @db.UniqueIdentifier
  number           String    @unique @db.NVarChar(20)
  requisitionId    String    @db.UniqueIdentifier  // 1 requisição pode gerar N pedidos
  companyId        String    @db.UniqueIdentifier
  branchErpCode    String    @db.NVarChar(50)
  branchName       String    @db.NVarChar(255)
  supplierErpCode  String    @db.NVarChar(50)
  supplierName     String    @db.NVarChar(255)
  buyerId          String    @db.UniqueIdentifier
  status           String    @default("DRAFT") @db.NVarChar(25)
  paymentCondition String?   @db.NVarChar(255)
  /**
   * Transportadora escolhida no convert (Linx.TRANSPORTADORAS.nome).
   * Quando NULL, usa CompanyErpConfig.transportadoraPadrao na gravação.
   */
  transportadora   String?   @db.NVarChar(25)
  deliveryAddress  String?   @db.NVarChar(500)
  expectedDelivery DateTime?
  totalAmount      Decimal   @default(0) @db.Decimal(15, 2)
  notes            String?   @db.NVarChar(Max)
  currentTierLevel Int?
  erpPedido        String?   @db.NVarChar(50)        // COMPRAS.PEDIDO gerado no ERP
  erpStagingId     String?   @unique @db.NVarChar(50) // idempotência no envio ao ERP
  pendingErpSince  DateTime?
  integratedAt     DateTime?
  // ── Sync-back financeiro (mão de volta do ERP) ──
  // Eixo ORTOGONAL ao `status` operacional (recebimento). Preenchido pelo
  // erp-back-sync a partir das entradas de NF (ENTRADAS) + saldo do título
  // (W_CTB_A_PAGAR_PARCELA_SALDO) no Linx. Fecha "até a conciliação do
  // pagamento" do PRD §11.
  financialStatus   String    @default("PENDENTE") @db.NVarChar(20) // PENDENTE | FATURADO | PARCIALMENTE_PAGO | PAGO
  invoicedAt        DateTime? // 1ª entrada de NF contra o pedido (Faturado)
  paidAt            DateTime? // saldo do(s) título(s) zerou (Pago)
  financialSyncedAt DateTime? // última verificação do back-sync financeiro
  submittedAt      DateTime?
  approvedAt       DateTime?
  sentToSupplierAt DateTime?
  cancelledAt      DateTime?
  cancellationReason String? @db.NVarChar(Max)
  /** Última edição: motivo + autor + timestamp. Histórico fica no AuditLog. */
  lastEditReason   String?   @db.NVarChar(Max)
  lastEditedAt     DateTime?
  lastEditedById   String?   @db.UniqueIdentifier
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  requisition   Requisition         @relation(fields: [requisitionId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  company       Company             @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  buyer         User                @relation(fields: [buyerId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  items         PurchaseOrderItem[]
  approvalSteps ApprovalStep[]
  receivings    Receiving[]
  fundRequest   FundRequest?
  attachments   Attachment[]
  fiscalDocuments FiscalDocument[] @relation("FiscalDocumentLinked")

  @@index([companyId, status])
  @@index([expectedDelivery, status])
  // findAll padrão: WHERE companyId ORDER BY createdAt DESC.
  @@index([companyId, createdAt(sort: Desc)])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                   String   @id @default(uuid()) @db.UniqueIdentifier
  purchaseOrderId      String   @db.UniqueIdentifier
  requisitionItemId    String?  @db.UniqueIdentifier
  itemErpCode          String?  @db.NVarChar(50)
  itemDescription      String   @db.NVarChar(500)
  quantity             Decimal  @db.Decimal(15, 4)
  unit                 String   @db.NVarChar(20)
  unitPrice            Decimal  @db.Decimal(15, 2)
  totalPrice           Decimal  @db.Decimal(15, 2)
  accountingAccount    String   @db.NVarChar(20)
  accountName          String?  @db.NVarChar(255)
  branchRateioCode     String   @db.NVarChar(20)
  branchRateioDesc     String?  @db.NVarChar(100)
  costCenterRateioCode String   @db.NVarChar(20)
  costCenterRateioDesc String?  @db.NVarChar(100)
  receivedQty          Decimal  @default(0) @db.Decimal(15, 4)
  /**
   * Quantidade já cancelada (PRD RN-OC-03). Quando `receivedQty +
   * cancelledQty >= quantity`, o item está fechado. Sempre que muda,
   * o backend recomputa o status do pedido (CANCELLED quando todos os
   * itens são cancelados).
   */
  cancelledQty         Decimal  @default(0) @db.Decimal(15, 4)
  cancelledAt          DateTime?
  cancellationReason   String?  @db.NVarChar(500)
  notes                String?  @db.NVarChar(Max)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  purchaseOrder  PurchaseOrder            @relation(fields: [purchaseOrderId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  receivingItems ReceivingItem[]
  rateios        PurchaseOrderItemRateio[]

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

// Snapshot do rateio do item do pedido — copiado da requisição na conversão.
// É o que vai para o ERP; congelado, não muda com alterações de template.
model PurchaseOrderItemRateio {
  id                  String   @id @default(uuid()) @db.UniqueIdentifier
  purchaseOrderItemId String   @db.UniqueIdentifier
  kind                String   @db.NVarChar(15)  // BRANCH | COST_CENTER
  rateioCode          String   @db.NVarChar(20)
  targetCode          String   @db.NVarChar(20)
  branchCode          String?  @db.NVarChar(20)
  percentage          Decimal  @db.Decimal(9, 4)
  amount              Decimal  @db.Decimal(15, 2)
  createdAt           DateTime @default(now())

  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([purchaseOrderItemId])
  @@index([kind, targetCode])
  @@map("purchase_order_item_rateios")
}

// ============================================================
// SOLICITAÇÃO DE VERBA (SV) — espelha CTB_SOLICITACAO_VERBA
// requisitionId / purchaseOrderId opcionais:
//   SV avulsa (sem NF) ou adiantamento vinculado a um PC
// ============================================================

model FundRequest {
  id              String    @id @default(uuid()) @db.UniqueIdentifier
  number          String    @unique @db.NVarChar(20)  // SV-2026-000001
  companyId       String    @db.UniqueIdentifier
  requisitionId   String?   @unique @db.UniqueIdentifier
  purchaseOrderId String?   @unique @db.UniqueIdentifier
  requesterId     String    @db.UniqueIdentifier
  title           String    @db.NVarChar(255)
  status          String    @default("DRAFT") @db.NVarChar(20)
  totalAmount     Decimal   @default(0) @db.Decimal(15, 2)
  currentTierLevel Int?
  erpSolicitacao  String?   @db.NVarChar(50)
  erpStagingId    String?   @unique @db.NVarChar(50)
  pendingErpSince DateTime?
  integratedAt    DateTime?
  // ── Sync-back financeiro (compensação/pagamento do adiantamento) ──
  // Preenchido pelo erp-back-sync a partir do saldo da SV no Linx
  // (W_CTB_SOLICITACAO_VERBA_SALDO.VALOR_A_PAGAR ≤ 0 = compensado/pago).
  financialStatus   String    @default("PENDENTE") @db.NVarChar(20) // PENDENTE | PARCIALMENTE_PAGO | PAGO
  paidAt            DateTime? // saldo da SV zerou (adiantamento compensado/pago)
  financialSyncedAt DateTime?
  // Última mensagem de erro na tentativa de gravação no Linx. Limpado
  // automaticamente quando a integração tem sucesso. Permite que a UI
  // mostre "Falha na integração" com tooltip em vez de só "—" silencioso
  // na coluna Nº Linx.
  lastErpError    String?   @db.NVarChar(Max)
  lastErpAttemptAt DateTime?
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?   @db.NVarChar(Max)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  company       Company           @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  requisition   Requisition?      @relation(fields: [requisitionId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  purchaseOrder PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  requester     User              @relation(fields: [requesterId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  items         FundRequestItem[]
  approvalSteps ApprovalStep[]
  attachments   Attachment[]

  @@index([companyId, status])
  @@map("fund_requests")
}

model FundRequestItem {
  id                   String   @id @default(uuid()) @db.UniqueIdentifier
  fundRequestId        String   @db.UniqueIdentifier
  itemErpCode          String?  @db.NVarChar(50)
  description          String   @db.NVarChar(500)
  beneficiaryName      String   @db.NVarChar(255)
  beneficiaryBank      String?  @db.NVarChar(10)
  beneficiaryAgency    String?  @db.NVarChar(10)
  beneficiaryAccount   String?  @db.NVarChar(30)
  accountingAccount    String   @db.NVarChar(20)
  accountName          String?  @db.NVarChar(255)
  branchRateioCode     String   @db.NVarChar(20)
  branchRateioDesc     String?  @db.NVarChar(100)
  costCenterRateioCode String   @db.NVarChar(20)
  costCenterRateioDesc String?  @db.NVarChar(100)
  amount               Decimal  @db.Decimal(15, 2)
  dueDate              DateTime
  notes                String?  @db.NVarChar(Max)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  fundRequest FundRequest @relation(fields: [fundRequestId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([fundRequestId])
  @@map("fund_request_items")
}

// ============================================================
// FLUXO DE APROVAÇÃO SEQUENCIAL
// Serve para Requisition, PurchaseOrder e FundRequest
// ============================================================

model ApprovalStep {
  id                  String    @id @default(uuid()) @db.UniqueIdentifier
  companyId           String    @db.UniqueIdentifier
  entityType          String    @db.NVarChar(20)  // REQUISITION | PURCHASE_ORDER | FUND_REQUEST
  requisitionId       String?   @db.UniqueIdentifier
  purchaseOrderId     String?   @db.UniqueIdentifier
  fundRequestId       String?   @db.UniqueIdentifier
  teamApprovalLevelId String?   @db.UniqueIdentifier  // nível de origem (rastreio)
  level               Int
  levelName           String    @db.NVarChar(50)      // snapshot do nome do nível
  // Nullable: quando o nível tem aprovador dinâmico por cargo (ex.: "qualquer
  // Supervisor da filial X"), o step não pré-associa uma pessoa. Decide em
  // runtime quem pode decidir, baseado no User.positionId + UserBranchAssignment.
  assignedApproverId  String?   @db.UniqueIdentifier
  decidedById         String?   @db.UniqueIdentifier  // quem de fato decidiu (aprovador ou delegado)
  status              String    @default("PENDING") @db.NVarChar(10)
  decidedAt           DateTime?
  comments            String?   @db.NVarChar(Max)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  requisition       Requisition?       @relation(fields: [requisitionId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  purchaseOrder     PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  fundRequest       FundRequest?       @relation(fields: [fundRequestId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  teamApprovalLevel TeamApprovalLevel? @relation(fields: [teamApprovalLevelId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  assignedApprover  User?              @relation("stepApprover", fields: [assignedApproverId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  decidedBy         User?              @relation("stepDecider", fields: [decidedById], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([requisitionId, level])
  @@index([purchaseOrderId, level])
  @@index([fundRequestId, level])
  @@index([assignedApproverId, status])
  @@map("approval_steps")
}

// ============================================================
// RECEBIMENTO / MEDIÇÃO
// ============================================================

model Receiving {
  id               String    @id @default(uuid()) @db.UniqueIdentifier
  number           String    @unique @db.NVarChar(20)
  purchaseOrderId  String    @db.UniqueIdentifier
  companyId        String    @db.UniqueIdentifier
  receivedById     String    @db.UniqueIdentifier
  status           String    @default("DRAFT") @db.NVarChar(15)
  receivedAt       DateTime
  measurementStart DateTime?
  measurementEnd   DateTime?
  completionPct    Decimal?  @db.Decimal(5, 2)
  notes            String?   @db.NVarChar(Max)
  divergenceNotes  String?   @db.NVarChar(Max)
  confirmedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  purchaseOrder PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  receivedBy    User            @relation(fields: [receivedById], references: [id], onUpdate: NoAction, onDelete: NoAction)
  items         ReceivingItem[]
  attachments   Attachment[]

  @@index([purchaseOrderId])
  @@map("receivings")
}

model ReceivingItem {
  id                  String   @id @default(uuid()) @db.UniqueIdentifier
  receivingId         String   @db.UniqueIdentifier
  purchaseOrderItemId String   @db.UniqueIdentifier
  receivedQty         Decimal  @db.Decimal(15, 4)
  acceptedQty         Decimal  @db.Decimal(15, 4)
  rejectedQty         Decimal  @default(0) @db.Decimal(15, 4)
  rejectionReason     String?  @db.NVarChar(Max)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  receiving         Receiving         @relation(fields: [receivingId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("receiving_items")
}

// ============================================================
// AUDITORIA (mascarar CPF/CNPJ/dados bancários — LGPD)
// ============================================================

model AuditLog {
  id         String   @id @default(uuid()) @db.UniqueIdentifier
  companyId  String   @db.UniqueIdentifier
  userId     String   @db.UniqueIdentifier
  action     String   @db.NVarChar(50)
  entityType String   @db.NVarChar(100)
  entityId   String   @db.UniqueIdentifier
  before     String?  @db.NVarChar(Max)
  after      String?  @db.NVarChar(Max)
  ipAddress  String?  @db.NVarChar(50)
  userAgent  String?  @db.NVarChar(500)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([companyId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// NOTIFICAÇÕES
// ============================================================

model Notification {
  id         String    @id @default(uuid()) @db.UniqueIdentifier
  companyId  String    @db.UniqueIdentifier
  userId     String    @db.UniqueIdentifier
  type       String    @db.NVarChar(30)
  title      String    @db.NVarChar(255)
  body       String    @db.NVarChar(Max)
  entityType String?   @db.NVarChar(100)
  entityId   String?   @db.UniqueIdentifier
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([userId, readAt])
  @@map("notifications")
}

// ============================================================
// ANEXOS (MVP: pasta no servidor; Fase 2: MinIO/S3)
// ============================================================

model Attachment {
  id              String    @id @default(uuid()) @db.UniqueIdentifier
  companyId       String    @db.UniqueIdentifier
  requisitionId   String?   @db.UniqueIdentifier
  purchaseOrderId String?   @db.UniqueIdentifier
  fundRequestId   String?   @db.UniqueIdentifier
  receivingId     String?   @db.UniqueIdentifier
  filename        String    @db.NVarChar(255)
  storageKey      String    @db.NVarChar(500)
  sizeBytes       Int
  mimeType        String    @db.NVarChar(100)
  uploadedById    String    @db.UniqueIdentifier
  createdAt       DateTime  @default(now())
  // Tipo do anexo — usado pra validar regras de governança que dependem
  // do CONTEÚDO do anexo, não só da existência (ex.: RN-REQ-02 exige 3
  // cotações). Valores em AttachmentKind (TS const). Default 'OTHER' pra
  // não quebrar uploads antigos sem kind explícito.
  kind            String    @default("OTHER") @db.NVarChar(30)

  requisition   Requisition?   @relation(fields: [requisitionId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  fundRequest   FundRequest?   @relation(fields: [fundRequestId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  receiving     Receiving?     @relation(fields: [receivingId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  quotation     Quotation?

  @@index([requisitionId])
  @@index([purchaseOrderId])
  @@index([fundRequestId])
  @@index([receivingId])
  @@index([requisitionId, kind])
  @@map("attachments")
}

// ============================================================
// COTAÇÕES (propostas de fornecedores anexadas à requisição)
// ============================================================

/**
 * Proposta de cotação anexada pelo solicitante. Cada cotação tem o
 * CNPJ do fornecedor, sua condição de pagamento e uma tabela de itens
 * (qty + preço unitário). O aprovador pode selecionar uma cotação
 * como vencedora — isso substitui o fornecedor + condição + itens da
 * requisição original.
 *
 * Se `supplierErpCode` for null, o fornecedor não está cadastrado no
 * Linx. Quando uma cotação assim vence, marcamos
 * `requisition.winningQuotationNeedsErp = true` pra um job/admin criar
 * o fornecedor no ERP depois.
 */
model Quotation {
  id                    String          @id @default(uuid()) @db.UniqueIdentifier
  companyId             String          @db.UniqueIdentifier
  requisitionId         String          @db.UniqueIdentifier
  /** Anexo (PDF/imagem) que representa esta cotação. Único por cotação. */
  attachmentId          String?         @unique @db.UniqueIdentifier
  /** CNPJ do fornecedor (só dígitos, 14 chars). */
  supplierCnpj          String          @db.NVarChar(14)
  supplierName          String          @db.NVarChar(200)
  /** Código do fornecedor no ERP (null se ainda não cadastrado). */
  supplierErpCode       String?         @db.NVarChar(20)
  /**
   * Dados públicos do CNPJ (BrasilAPI) — usados pra criação automática
   * no ERP quando o fornecedor não está cadastrado e a cotação vence.
   * Capturados no momento do cadastro da cotação pra refletir o que o
   * solicitante viu (a Receita pode mudar entre a cotação e o cadastro).
   */
  supplierFantasia      String?         @db.NVarChar(200)
  supplierEmail         String?         @db.NVarChar(200)
  supplierTelefone      String?         @db.NVarChar(50)
  supplierLogradouro    String?         @db.NVarChar(200)
  supplierNumero        String?         @db.NVarChar(20)
  supplierBairro        String?         @db.NVarChar(100)
  supplierCidade        String?         @db.NVarChar(100)
  supplierUf            String?         @db.NVarChar(2)
  supplierCep           String?         @db.NVarChar(10)
  supplierCnae          String?         @db.NVarChar(200)
  paymentConditionCode  String?         @db.NVarChar(20)
  paymentConditionDesc  String?         @db.NVarChar(100)
  totalAmount           Decimal         @db.Decimal(18, 2)
  notes                 String?         @db.NVarChar(Max)
  isWinner              Boolean         @default(false)
  selectedAt            DateTime?
  selectedById          String?         @db.UniqueIdentifier
  /**
   * Justificativa da escolha — preenchida pelo aprovador no momento da
   * seleção. Permite auditar por que ESTA cotação foi escolhida em vez
   * das outras (ex.: "menor prazo de entrega" ou "única com garantia").
   */
  selectionReason       String?         @db.NVarChar(Max)
  createdAt             DateTime        @default(now())
  createdById           String          @db.UniqueIdentifier

  requisition   Requisition     @relation(fields: [requisitionId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  attachment    Attachment?     @relation(fields: [attachmentId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  selectedBy    User?           @relation("quotationSelectedBy", fields: [selectedById], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdBy     User            @relation("quotationCreatedBy", fields: [createdById], references: [id], onUpdate: NoAction, onDelete: NoAction)
  items         QuotationItem[]

  @@index([requisitionId])
  @@index([supplierCnpj])
  @@map("quotations")
}

model QuotationItem {
  id           String   @id @default(uuid()) @db.UniqueIdentifier
  quotationId  String   @db.UniqueIdentifier
  /** Posição na lista (ordem de exibição). */
  position     Int
  description  String   @db.NVarChar(500)
  unit         String?  @db.NVarChar(20)
  quantity     Decimal  @db.Decimal(18, 4)
  unitPrice    Decimal  @db.Decimal(18, 4)
  totalPrice   Decimal  @db.Decimal(18, 2)

  quotation    Quotation @relation(fields: [quotationId], references: [id], onUpdate: NoAction, onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

// ============================================================
// LOGS DE INTEGRAÇÃO ERP (envio de OC/SV ao ERP)
// ============================================================

model IntegrationLog {
  id               String    @id @default(uuid()) @db.UniqueIdentifier
  companyId        String    @db.UniqueIdentifier
  source           String    @db.NVarChar(50)   // ERP_GUESS | ERP_HRG3
  jobType          String    @db.NVarChar(100)  // SEND_PO | SEND_SV | ...
  status           String    @db.NVarChar(10)   // SUCCESS | PARTIAL | FAILED
  recordsProcessed Int       @default(0)
  errorDetails     String?   @db.NVarChar(Max)
  durationMs       Int?
  executedAt       DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([companyId, source, executedAt])
  @@index([source, status, executedAt])
  @@map("integration_logs")
}

// ============================================================
// SEQUÊNCIAS DE DOCUMENTOS (referência; geração usa SQL Server SEQUENCE)
//   CREATE SEQUENCE dbo.seq_REQ_GUESS_2026 START WITH 1 INCREMENT BY 1;
//   SELECT NEXT VALUE FOR dbo.seq_REQ_GUESS_2026
// ============================================================

model DocumentSequence {
  id           String   @id @default(uuid()) @db.UniqueIdentifier
  companyId    String   @db.UniqueIdentifier
  docType      String   @db.NVarChar(10)   // REQ | OC | SV | REC
  year         Int
  sequenceName String   @db.NVarChar(100)
  createdAt    DateTime @default(now())

  @@unique([companyId, docType, year])
  @@map("document_sequences")
}

/**
 * Log de notificações de aprovação enviadas pra diretor de PA.
 * Idempotência: um (companyId, pedido) só dispara e-mail uma vez.
 * Se o envio falhar, fica marcado e o cron tenta de novo no próximo tick
 * (até `attemptCount` chegar num teto razoável).
 */
model PaApprovalNotification {
  id            String   @id @default(uuid()) @db.UniqueIdentifier
  companyId     String   @db.UniqueIdentifier
  pedido        String   @db.NVarChar(20)
  approverEmail String   @db.NVarChar(255)
  firstAttempt  DateTime @default(now())
  lastAttempt   DateTime @default(now())
  attemptCount  Int      @default(1)
  success       Boolean  @default(false)
  errorMessage  String?  @db.NVarChar(500)

  @@unique([companyId, pedido])
  @@map("pa_approval_notifications")
}

/**
 * Reagendamento de entrega de pedidos PA — registra o histórico DE/PARA.
 *
 * `scope = 'order'` aplica a TODOS os itens abertos do pedido (produto/cor/
 * entregaOriginal ficam NULL). `scope = 'item'` aplica só ao item específico
 * (chaveado pela ENTREGA *original* no ERP, não pela vigente — assim a chave
 * fica estável mesmo após múltiplos reagendamentos).
 *
 * `fromDate` é redundante mas fica explícito pra timeline mostrar
 * "DE 2026-03-15 PARA 2026-04-02" sem reconstruir o histórico.
 *
 * Não há FK pro pedido em si — o pedido vive no ERP, identificamos por
 * número (`pedido`). FK só pro changedBy (user do P2P).
 */
model PaDeliveryChange {
  id              String   @id @default(uuid()) @db.UniqueIdentifier
  companyId       String   @db.UniqueIdentifier
  pedido          String   @db.NVarChar(20)
  scope           String   @db.NVarChar(10) // 'order' | 'item'
  produto         String?  @db.NVarChar(50)
  cor             String?  @db.NVarChar(20)
  entregaOriginal DateTime?
  fromDate        DateTime
  toDate          DateTime
  reason          String   @db.NVarChar(500)
  changedById     String   @db.UniqueIdentifier
  changedBy       User     @relation("PaDeliveryChangeUser", fields: [changedById], references: [id])
  createdAt       DateTime @default(now())

  @@index([companyId, pedido])
  @@map("pa_delivery_changes")
}
