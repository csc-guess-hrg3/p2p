# ============================================================
# P2P — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no repositório
# ============================================================

# --- Aplicação ---
NODE_ENV=development
PORT=3000

# --- Banco de Dados P2P (SQL Server) ---
# Formato: sqlserver://HOST:PORTA;database=BANCO;user=USUARIO;password=SENHA;trustServerCertificate=true
DATABASE_URL="sqlserver://MAQUINA21:1433;database=P2P_DB;user=p2p_app;password=SENHA_AQUI;trustServerCertificate=true"

# --- Bancos ERP (leitura apenas via views cross-database) ---
ERP_EMPRESA1_DB=ERP_EMPRESA1_DB
ERP_EMPRESA2_DB=ERP_EMPRESA2_DB

# --- JWT ---
JWT_SECRET=TROQUE_POR_SEGREDO_FORTE_64_CHARS
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=TROQUE_POR_SEGREDO_FORTE_DIFERENTE_64_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# --- LDAP / Active Directory ---
LDAP_URL=ldap://192.168.10.8:389
LDAP_BASE_DN=DC=corp,DC=local
LDAP_BIND_DN=CN=P2P Service,CN=Users,DC=corp,DC=local
LDAP_BIND_PASSWORD=SENHA_DA_CONTA_P2P_SERVICE

# --- Redis (Memurai no Windows) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- E-mail ---
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@seudominio.com.br
SMTP_PASSWORD=SENHA_SMTP
SMTP_FROM="P2P Sistema <noreply@seudominio.com.br>"

# --- MinIO / S3 (armazenamento de arquivos) ---
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=p2p-documents
STORAGE_USE_SSL=false

# --- Configurações P2P ---
# URL do frontend (CORS)
FRONTEND_URL=http://localhost:5173
# Sessão máxima inativa (minutos)
SESSION_TIMEOUT_MINUTES=60
