# ============================================================
# P2P - Environment variables
#
# Local development:
#   copy to backend/.env and fill DEV/HML values.
#
# Production/HML runtime:
#   prefer PM2/Windows service variables/Vault. Do not keep .env files
#   with real secrets on a network share. See backend/PRODUCTION-SETUP.md.
#
# Never commit .env, .env.hml, pm2.config.js, or real secrets.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000

# --- P2P database (SQL Server) ---
# Used by Prisma Migrate and ad-hoc scripts.
DATABASE_URL="sqlserver://HOST:1433;database=P2P_DB;user=USUARIO;password={SENHA};encrypt=true;trustServerCertificate=true"

# Used by PrismaClient with the MSSQL adapter.
DB_HOST=HOST
DB_PORT=1433
DB_NAME=P2P_DB
DB_USER=USUARIO
DB_PASSWORD=SENHA
# Pool de conexões (opcional — defaults: min=5 max=30)
DB_POOL_MIN=5
DB_POOL_MAX=30

# --- Allowed ERP databases ---
# Runtime allow-list is also enforced in src/common/erp/safe-db-name.ts.
ERP_GUESS_DB=GUESS_PRODUCAO
ERP_HRG3_DB=DB_HRG3

# --- JWT ---
# Generate strong, different values per environment:
# node -e "const c=require('crypto');console.log(c.randomBytes(48).toString('base64'))"
JWT_SECRET=TROQUE_POR_SEGREDO_FORTE_48_BYTES_BASE64
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=TROQUE_POR_SEGREDO_FORTE_DIFERENTE_48_BYTES_BASE64
JWT_REFRESH_EXPIRES_IN=7d

# --- LDAP / Active Directory ---
LDAP_URL=ldap://AD_HOST:389
LDAP_BASE_DN=DC=exemplo,DC=local
LDAP_BIND_DN=CN=P2P Service,CN=Users,DC=exemplo,DC=local
LDAP_BIND_PASSWORD=TROQUE_PELA_SENHA_DO_BIND

# --- Redis ---
# Roadmap/BullMQ/distributed throttling. Not every module uses Redis yet.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Corporate SMTP / internal notifications ---
# Internal notifications use SMTP_* as the corporate fallback.
# Purchase Order e-mail to suppliers uses company_erp_configs.smtp* per company.
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@seudominio.com.br
SMTP_PASSWORD=TROQUE_PELA_SENHA_SMTP
SMTP_FROM=noreply@seudominio.com.br
SMTP_FROM_NAME="P2P"

# --- MinIO / S3 (future attachment storage) ---
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=TROQUE_PELA_CHAVE_DO_STORAGE
STORAGE_BUCKET=p2p-documents
STORAGE_USE_SSL=false

# --- Qive / Arquivei ---
QIVE_SANDBOX=true
QIVE_API_ID=TROQUE_PELO_API_ID
QIVE_API_KEY=TROQUE_PELO_API_KEY

# --- Frontend / CORS ---
# Comma-separated list is preferred for real environments.
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=http://localhost:5173,https://p2p.hrg3.com.br

# --- Security ---
# AES-256-GCM key used by SecretService for at-rest secrets such as smtpPassword.
# Required in real PROD/HML. Empty means plaintext passthrough for local dev only.
# Generate 32 bytes hex:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_ENCRYPTION_KEY=

# Session cookies are httpOnly p2p_token / p2p_refresh.
AUTH_MODE=cookie
COOKIE_SAMESITE=lax

# Cloudflare Turnstile. Empty disables captcha validation.
TURNSTILE_SECRET_KEY=

# Swagger is disabled when NODE_ENV=production unless explicitly true.
SWAGGER_ENABLED=false

# --- Sentry (error tracking) ---
# Obtenha o DSN em https://sentry.io → seu projeto → Settings → DSN.
# Deixe vazio para desativar (no-op).
SENTRY_DSN=
