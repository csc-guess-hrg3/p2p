# ============================================================
# P2P — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no repositório
# ============================================================

# --- Aplicação ---
NODE_ENV=development
PORT=3000

# --- Banco de Dados P2P (SQL Server) ---
# DATABASE_URL: usada pelo Prisma Migrate
DATABASE_URL="sqlserver://HOST:1433;database=P2P_DB;user=USUARIO;password={SENHA};encrypt=true;trustServerCertificate=true"

# Parâmetros separados: usados pelo PrismaClient (driver adapter MSSQL)
DB_HOST=HOST
DB_PORT=1433
DB_NAME=P2P_DB
DB_USER=USUARIO
DB_PASSWORD=SENHA

# --- Bancos ERP (leitura via views cross-database no mesmo servidor) ---
ERP_GUESS_DB=GUESS_PRODUCAO
ERP_HERING_DB=DB_HRG3

# --- JWT ---
JWT_SECRET=TROQUE_POR_SEGREDO_FORTE_64_CHARS
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=TROQUE_POR_SEGREDO_FORTE_DIFERENTE_64_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# --- LDAP / Active Directory ---
LDAP_URL=ldap://192.168.10.8:389
LDAP_BASE_DN=DC=corp,DC=local
LDAP_BIND_DN=CN=P2P Service,CN=Users,DC=corp,DC=local
LDAP_BIND_PASSWORD=SENHA_DA_CONTA_P2P_SERVICE

# --- Redis (Memurai no Windows) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- E-mail ---
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@seudominio.com.br
SMTP_PASSWORD=SENHA_SMTP
SMTP_FROM="P2P Sistema <noreply@seudominio.com.br>"

# --- MinIO / S3 (armazenamento de arquivos) ---
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=p2p-documents
STORAGE_USE_SSL=false

# --- Configurações P2P ---
# URL(s) do frontend (CORS). Aceita lista separada por vírgula.
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=http://localhost:5173,https://p2p.hrg3.com.br
# Sessão máxima inativa (minutos)
SESSION_TIMEOUT_MINUTES=60

# --- Segurança ---
# Chave (≥ 32 chars) usada para criptografar smtpPassword e outros segredos
# at-rest (AES-256-GCM via SecretService). Em PROD: gere uma forte e mantenha
# fora do repositório. Vazia => modo passthrough (não criptografa — só dev).
SECRET_ENCRYPTION_KEY=

# Política de SameSite dos cookies de sessão (httpOnly p2p_token / p2p_refresh)
# 'lax' (default), 'strict' ou 'none' (exige HTTPS quando NODE_ENV=production).
COOKIE_SAMESITE=lax

# --- Modo Demonstração ---
# Quando true, libera /auth/demo-users e /auth/demo-login (bypassa LDAP).
# NUNCA ligar em produção real. Use junto com `node seed-demo.js`.
DEMO_MODE_ENABLED=false
